generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  admin
  member
}

enum UserStatus {
  active
  disabled
}

model User {
  id                 String     @id @default(uuid())
  username           String     @unique
  email              String     @unique
  passwordHash       String
  role               UserRole   @default(member)
  status             UserStatus @default(active)
  mustChangePassword Boolean    @default(false)
  createdAt          DateTime   @default(now())
  lastLoginAt        DateTime?

  createdConnections AppConnection[] @relation("ConnectionCreatedBy")
  createdTokens      McpToken[]      @relation("TokenCreatedBy")
  createdOAuthClients OAuthClient[]           @relation("OAuthClientCreatedBy")
  oauthCodes          OAuthAuthorizationCode[] @relation("OAuthCodeIssuedTo")
  oauthAccessTokens   OAuthAccessToken[]       @relation("OAuthAccessTokenIssuedTo")
  oauthRefreshTokens  OAuthRefreshToken[]      @relation("OAuthRefreshTokenIssuedTo")

  @@map("users")
}

model AppConnection {
  id                    String   @id @default(uuid())
  appType               String
  name                  String
  baseUrl               String
  encryptedCredentials  String
  enabled               Boolean  @default(true)
  createdAt             DateTime @default(now())
  createdById           String?
  createdBy             User?    @relation("ConnectionCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  toolSettings          ToolSetting[]
  toolCallLogs          ToolCallLog[]

  @@map("app_connections")
}

model ToolSetting {
  id           String        @id @default(uuid())
  connectionId String
  connection   AppConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  toolName     String
  enabled      Boolean       @default(true)

  @@unique([connectionId, toolName])
  @@map("tool_settings")
}

model McpToken {
  id            String    @id @default(uuid())
  name          String
  tokenHash     String    @unique
  scopes        String[]  @default([])
  createdAt     DateTime  @default(now())
  lastUsedAt    DateTime?
  revokedAt     DateTime?
  createdById   String?
  createdBy     User?     @relation("TokenCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  toolCallLogs  ToolCallLog[]

  @@map("mcp_tokens")
}

enum ToolCallStatus {
  success
  error
}

model ToolCallLog {
  id                 String            @id @default(uuid())
  tokenId            String?
  token              McpToken?         @relation(fields: [tokenId], references: [id], onDelete: SetNull)
  oauthAccessTokenId String?
  oauthAccessToken   OAuthAccessToken? @relation(fields: [oauthAccessTokenId], references: [id], onDelete: SetNull)
  connectionId       String?
  connection         AppConnection?    @relation(fields: [connectionId], references: [id], onDelete: SetNull)
  toolName           String
  status             ToolCallStatus
  durationMs         Int
  errorSummary       String?
  createdAt          DateTime          @default(now())

  @@index([createdAt])
  @@map("tool_call_logs")
}

model Setting {
  key   String @id
  value String

  @@map("settings")
}

enum OAuthClientAuthMethod {
  none // public clients only for v1 — PKCE required, no client secret
}

model OAuthClient {
  id                      String                 @id @default(uuid())
  clientName              String
  redirectUris            String[]
  tokenEndpointAuthMethod OAuthClientAuthMethod  @default(none)
  grantTypes              String[]               @default(["authorization_code", "refresh_token"])
  registrationSource      String // "dcr" | "manual"
  createdAt               DateTime               @default(now())
  revokedAt               DateTime?
  createdById             String?
  createdBy               User?                  @relation("OAuthClientCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  authorizationCodes      OAuthAuthorizationCode[]
  accessTokens            OAuthAccessToken[]
  refreshTokens           OAuthRefreshToken[]

  @@map("oauth_clients")
}

model OAuthAuthorizationCode {
  id                  String      @id @default(uuid())
  codeHash            String      @unique
  clientId            String
  client              OAuthClient @relation(fields: [clientId], references: [id], onDelete: Cascade)
  userId              String
  user                User        @relation("OAuthCodeIssuedTo", fields: [userId], references: [id], onDelete: Cascade)
  redirectUri         String
  codeChallenge       String
  codeChallengeMethod String      @default("S256")
  resource            String?
  scopes              String[]    @default([])
  expiresAt           DateTime
  consumedAt          DateTime?

  @@map("oauth_authorization_codes")
}

model OAuthAccessToken {
  id         String    @id @default(uuid())
  tokenHash  String    @unique
  clientId   String
  client     OAuthClient @relation(fields: [clientId], references: [id], onDelete: Cascade)
  userId     String
  user       User      @relation("OAuthAccessTokenIssuedTo", fields: [userId], references: [id], onDelete: Cascade)
  scopes     String[]  @default([])
  expiresAt  DateTime
  revokedAt  DateTime?
  createdAt  DateTime  @default(now())
  lastUsedAt DateTime?

  toolCallLogs ToolCallLog[]

  @@map("oauth_access_tokens")
}

model OAuthRefreshToken {
  id        String    @id @default(uuid())
  tokenHash String    @unique
  clientId  String
  client    OAuthClient @relation(fields: [clientId], references: [id], onDelete: Cascade)
  userId    String
  user      User      @relation("OAuthRefreshTokenIssuedTo", fields: [userId], references: [id], onDelete: Cascade)
  scopes    String[]  @default([])
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  @@map("oauth_refresh_tokens")
}
