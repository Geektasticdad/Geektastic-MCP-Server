# --- Postgres ---
DB_PASSWORD=change-me
DATABASE_URL=postgresql://mcp:change-me@postgres:5432/mcp

# --- App secrets (generate with: openssl rand -hex 32) ---
APP_ENCRYPTION_KEY=replace-with-64-char-hex-string
SESSION_SECRET=replace-with-a-long-random-string

# --- Bootstrap admin (only used on first run, when the users table is empty) ---
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-immediately

# --- Server ---
PORT=8080
NODE_ENV=production
# Set to "true" if the server sits behind a TLS-terminating reverse proxy
TRUST_PROXY=false
# The server's own externally-reachable origin, no trailing slash (e.g. what
# you'd point a Claude.ai Custom Connector or Claude Code at). Required for
# OAuth discovery metadata (RFC 8414/9728).
PUBLIC_BASE_URL=https://mcp.example.com
