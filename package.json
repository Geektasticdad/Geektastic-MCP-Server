{
  "name": "geektastic-mcp-server",
  "private": true,
  "version": "1.3.2",
  "license": "UNLICENSED",
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@11.10.0",
  "scripts": {
    "build": "pnpm --filter ./packages/shared build && pnpm --filter ./packages/connectors build && pnpm --filter ./apps/web build && pnpm --filter ./apps/server build",
    "dev:server": "pnpm --filter ./apps/server dev",
    "dev:web": "pnpm --filter ./apps/web dev",
    "prisma:generate": "pnpm --filter ./apps/server exec prisma generate",
    "prisma:push": "pnpm --filter ./apps/server exec prisma db push",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck"
  },
  "devDependencies": {
    "typescript": "^5.6.3"
  }
}
